# Application
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/alakh_service"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Firebase Admin (FCM push notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# AWS S3 (file uploads)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=alakh-service-uploads

# Email (nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@alakhservice.com

# SMS (TODO: configure Twilio/MSG91)
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=ALKSVC

# Platform Config
PLATFORM_COMMISSION_PERCENT=10
GST_PERCENT=18
REFUND_WINDOW_HOURS=24
REVIEW_EDIT_WINDOW_DAYS=7
REVIEW_REPORT_THRESHOLD=5
MIN_PAYOUT_AMOUNT=500

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:3002

# Bull (Redis Queue)
BULL_REDIS_HOST=localhost
BULL_REDIS_PORT=6379
