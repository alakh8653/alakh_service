root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.dart]
indent_size = 2
max_line_length = 80

[*.yaml]
indent_size = 2

[*.yml]
indent_size = 2

[*.json]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[Makefile]
indent_style = tab
indent_size = 4

[*.sh]
indent_size = 2

[*.gradle]
indent_size = 4

[*.java]
indent_size = 4

[*.kt]
indent_size = 4

[*.swift]
indent_size = 4
